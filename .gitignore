# Source archives — not needed for deployment
*.zip
*.rar
*.7z

# Raw high-res originals — WebP versions in images/*/webp/ are used instead
images/**/*.jpg
images/**/*.JPG
images/**/*.jpeg

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
*.swp

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
.env*
!.env.example
